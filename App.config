<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <connectionStrings>
    <!-- Inlocuieste PAROLA_TA cu parola setata la instalare PostgreSQL -->
    <add name="Ticketa"
         connectionString="Host=localhost;Port=5432;Database=ticketa;Username=postgres;Password=postgres;"
         providerName="Npgsql" />
  </connectionStrings>
  <appSettings>
    <!-- Folderul cu imagini relative la executabil (bin\Debug\net10.0-windows\Images) -->
    <add key="ImagesFolder" value="Images" />
  </appSettings>
</configuration>
